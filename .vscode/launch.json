{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Bootloader",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/bootloader.elf",
            "servertype": "stlink",
            "device": "STM32F407VGTx",
            "interface": "swd",
            "svdFile": "${config:stm32.cltPath}/STMicroelectronics_CMSIS_SVD/STM32F407.svd",
            "serverpath": "${workspaceFolder}/scripts/tools/gdbserver-wrapper.sh",
            "gdbPath": "${config:stm32.cltPath}/GNU-tools-for-STM32/bin/arm-none-eabi-gdb",
            "runToEntryPoint": "main",
            "preLaunchTask": "CMake: Build Bootloader"
        },
        {
            "name": "Debug Application",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/app.elf",
            "servertype": "stlink",
            "device": "STM32F407VGTx",
            "interface": "swd",
            "svdFile": "${config:stm32.cltPath}/STMicroelectronics_CMSIS_SVD/STM32F407.svd",
            "serverpath": "${workspaceFolder}/scripts/tools/gdbserver-wrapper.sh",
            "gdbPath": "${config:stm32.cltPath}/GNU-tools-for-STM32/bin/arm-none-eabi-gdb",
            "runToEntryPoint": "main",
            "preLaunchTask": "CMake: Build Application"
        },
        {
            "name": "Debug Full Firmware",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/app.elf",
            "servertype": "stlink",
            "device": "STM32F407VGTx",
            "interface": "swd",
            "svdFile": "${config:stm32.cltPath}/STMicroelectronics_CMSIS_SVD/STM32F407.svd",
            "serverpath": "${workspaceFolder}/scripts/tools/gdbserver-wrapper.sh",
            "gdbPath": "${config:stm32.cltPath}/GNU-tools-for-STM32/bin/arm-none-eabi-gdb",
            "runToEntryPoint": "main",
            "preLaunchTask": "CMake: Build All"
        }
    ]
}